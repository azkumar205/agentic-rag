{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AgenticRAG.Api (Debug + Watch)",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/src/AgenticRAG.Api/AgenticRAG.Api.csproj"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "AgenticRAG.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/AgenticRAG.Api/bin/Debug/net8.0/AgenticRAG.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/AgenticRAG.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "integratedTerminal"
    }
  ]
}
