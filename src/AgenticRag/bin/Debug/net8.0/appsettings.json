{
  "AzureOpenAI": {
    "Endpoint": "https://<your-openai>.openai.azure.com/",
    "ChatDeployment": "gpt-4o",
    "EmbeddingDeployment": "text-embedding-3-large",
    "EmbeddingDimensions": 3072
  },
  "AzureAISearch": {
    "Endpoint": "https://<your-search>.search.windows.net",
    "IndexName": "rag-index"
  },
  "DocumentIntelligence": {
    "Endpoint": "https://<your-docintel>.cognitiveservices.azure.com/"
  },
  "SqlServer": {
    "ConnectionString": "Server=<server>.database.windows.net;Database=<db>;Authentication=Active Directory Default;Encrypt=True;"
  },
  "Redis": {
    "ConnectionString": "<redis>.redis.cache.windows.net:10000,password=<key>,ssl=True",
    "SimilarityThreshold": 0.92
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
